# ============================================================
# Daily Digest Bot — 환경 변수 예시
# 실제 값은 `npx wrangler secret put <KEY>` 로 등록하세요.
# 로컬 개발 시에는 .dev.vars 파일에 복사해서 사용하세요.
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
TELEGRAM_CHAT_ID=987654321

# Telegram Webhook 인증용 랜덤 토큰 (관리자 엔드포인트에도 재사용)
# 생성: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...   # 선택 사항 (Claude 장애 시 fallback)

# YouTube
YOUTUBE_API_KEY=AIzaSy...
